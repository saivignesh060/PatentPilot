# ─── LLM / AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite
EMBEDDING_MODEL=gemini-embedding-2

# ─── EPO Open Patent Services (OPS) ───────────────────────────────────────────
# Register free at: developers.epo.org/user/register → Non-paying access
# My Apps → Add new App → copy Consumer Key + Secret
EPO_OPS_CONSUMER_KEY=your_epo_consumer_key
EPO_OPS_CONSUMER_SECRET=your_epo_consumer_secret

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Recommended: run locally → docker run -d -p 27017:27017 mongo
MONGODB_URI=mongodb://localhost:27017/patentpilot

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
